# VinmecPrep AI - single-service .env.example
# Copy thanh .env roi dien gia tri that

# App / Runtime
ENVIRONMENT=production
DEBUG=false
APP_NAME=VinmecPrep AI
APP_VERSION=2.0.0

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# LLM
LLM_MODEL=groq/qwen/qwen3-32b
LLM_API_BASE=
LLM_API_KEY=replace_with_llm_api_key
GROQ_API_KEY=replace_with_llm_api_key
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# Search
SERPER_API_KEY=replace_with_serper_api_key
SEARXNG_URL=
WEB_SEARCH_TOP_K=5

# Redis
REDIS_URL=redis://default:replace_with_render_key_value_password@your-redis-host:6379
REDIS_SESSION_TTL=86400
REDIS_CACHE_TTL=300

# Security
AGENT_API_KEY=replace_with_long_random_agent_api_key
TRAINER_API_KEY=replace_with_long_random_trainer_api_key
ALLOWED_ORIGINS=https://yourapp.onrender.com

# Limits / Cost Guard
RATE_LIMIT_RPM=10
MAX_INPUT_CHARS=2000
MONTHLY_BUDGET_USD=10.0
PRICE_INPUT_PER_1M_TOKENS_USD=0.27
PRICE_OUTPUT_PER_1M_TOKENS_USD=0.27

# Monitoring
SENTRY_DSN=
